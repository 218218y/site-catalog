# Copy this file to r2.env and fill in your Cloudflare R2 API details.
# Do not upload r2.env to GitHub/Netlify; it contains secrets.

# Cloudflare account ID. The upload endpoint will be:
# https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=your-cloudflare-account-id

# R2 API token credentials with permission to read/write the bargig-catalog bucket.
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Public image domain used only for preview output and documentation links.
# The actual Netlify bundle also uses this address through bundle-site-r2.bat.
R2_PUBLIC_URL=https://cdn.bargig-furniture.com

# Optional overrides. Usually keep these commented.
R2_BUCKET=bargig-catalog
R2_PREFIX=assets/pages
R2_ENDPOINT_URL=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
