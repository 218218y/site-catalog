# Keep source and generated text deterministic across Windows and GitHub CI.
* text=auto
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.md text eol=lf
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
# Cloudflare control files have no normal extension; keep them deterministic too.
_headers* text eol=lf
robots.txt text eol=lf
