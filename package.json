{
  "name": "site-catalog",
  "version": "1.0.0",
  "private": true,
  "description": "Static furniture catalog site and deterministic build tools",
  "scripts": {
    "setup": "npm run setup:python && npm run setup:browsers",
    "setup:python": "python tools/setup_python_env.py",
    "setup:browsers": "playwright install chromium",
    "build": "npm run build:local",
    "build:frontend": "python tools/build_frontend_assets.py",
    "check:frontend": "python tools/build_frontend_assets.py --check",
    "build:pages": "python tools/build_site_pages.py",
    "build:seo:private": "npm run build:local",
    "build:seo:public": "python tools/build_deploy_bundle.py --out dist/site-public-preview --seo-mode public --confirm-public-indexing --skip-if-current",
    "check:seo-routes": "python tools/seo_route_lock.py --check",
    "seo:routes:update": "python tools/seo_route_lock.py --update",
    "verify:seo:public": "python tools/run_with_project_python.py tools/verify_public_seo.py --out dist/site-public-preview --clean-legacy-artifacts",
    "verify:seo:public:full": "python tools/run_with_project_python.py tools/verify_public_seo.py --out dist/site-public-preview --force-audit --clean-legacy-artifacts",
    "verify:seo:public:rebuild": "python tools/run_with_project_python.py tools/verify_public_seo.py --out dist/site-public-preview --force-rebuild --clean-legacy-artifacts",
    "verify:seo:live": "python tools/run_with_project_python.py tools/audit_public_seo.py --live",
    "check:pages": "python tools/build_site_pages.py --check",
    "build:big-pages-viewer": "python tools/build_big_pages_viewer.py",
    "check:big-pages-viewer": "python tools/build_big_pages_viewer.py --check",
    "build:deploy": "python tools/build_deploy_bundle.py --out dist/site-upload-r2 --seo-mode private --skip-if-current --mirror-to dist/site-local --clean-legacy-artifacts",
    "build:deploy:private": "python tools/build_deploy_bundle.py --out dist/site-upload-r2 --seo-mode private --skip-if-current --mirror-to dist/site-local --clean-legacy-artifacts",
    "build:deploy:public": "python tools/run_with_project_python.py tools/verify_public_seo.py --out dist/site-public-preview --mirror-to dist/site-upload-r2 --mirror-to dist/site-local --clean-legacy-artifacts",
    "test:js": "python tools/verify_project.py --javascript-only",
    "pretest:python": "python tools/setup_python_env.py --quiet",
    "test:python": "python tools/verify_project.py --python-only",
    "pretest:e2e": "node tools/check_playwright_browser.js",
    "test:e2e": "playwright test",
    "pretest:e2e:update": "node tools/check_playwright_browser.js",
    "test:e2e:update": "node tools/update_visual_snapshots.js",
    "pretest": "python tools/setup_python_env.py --quiet",
    "test": "python tools/verify_project.py --quick",
    "preverify": "python tools/setup_python_env.py --quiet && node tools/check_playwright_browser.js",
    "verify": "python tools/verify_project.py",
    "verify:r2": "python tools/verify_remote_catalog_assets.py --base-url https://cdn.bargig-furniture.com",
    "telemetry:report": "python tools/telemetry_report.py --open",
    "build:local": "python tools/build_deploy_bundle.py --out dist/site-upload-r2 --seo-mode private --skip-if-current --mirror-to dist/site-local --clean-legacy-artifacts",
    "dev": "python tools/serve_site.py",
    "serve": "python tools/serve_site.py",
    "build:e2e": "python tools/build_deploy_bundle.py --out dist/site-local --seo-mode private --skip-if-current --clean-legacy-artifacts",
    "dev:check": "python tools/serve_site.py --ensure-current ask",
    "clean:artifacts": "python tools/clean_project_artifacts.py",
    "check:node-tools": "node tools/check_node_install_scripts.js",
    "postinstall": "node tools/check_node_install_scripts.js"
  },
  "devDependencies": {
    "@playwright/test": "1.55.1",
    "wrangler": "4.112.0"
  },
  "allowScripts": {
    "esbuild": true,
    "sharp": true,
    "workerd": true
  }
}
