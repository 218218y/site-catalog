{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://bargig-catalog.netlify.app",
          "http://localhost:8000",
          "http://127.0.0.1:8000"
        ],
        "methods": ["GET", "HEAD"],
        "headers": ["*"]
      },
      "exposeHeaders": ["ETag", "Content-Length", "Content-Type", "Cache-Control"],
      "maxAgeSeconds": 86400
    }
  ]
}
