# Cloudflare Pages / static hosting: keep this build out of search results while it is under construction.
# Do not replace this with robots.txt Disallow; Google must be able to crawl the page to see noindex.
/*
  X-Robots-Tag: noindex, nofollow, noimageindex, nosnippet, noarchive
  Strict-Transport-Security: max-age=31536000

# HTML/app shell must never be stored by browsers or CDN caches.
# Dashboard Cache Rules must not override these response headers for HTML routes.
# Cloudflare serves the public pages both as *.html and as clean extensionless URLs,
# so every public route is listed explicitly. This prevents stale HTML from requesting
# a content-hashed JavaScript file that belonged to an older deployment.
/
  Cache-Control: no-store, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store
  CDN-Cache-Control: no-store
/index
  Cache-Control: no-store, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store
  CDN-Cache-Control: no-store
/index.html
  Cache-Control: no-store, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store
  CDN-Cache-Control: no-store
/catalog
  Cache-Control: no-store, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store
  CDN-Cache-Control: no-store
/catalog/
  Cache-Control: no-store, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store
  CDN-Cache-Control: no-store
/catalog.html
  Cache-Control: no-store, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store
  CDN-Cache-Control: no-store
/favorites
  Cache-Control: no-store, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store
  CDN-Cache-Control: no-store
