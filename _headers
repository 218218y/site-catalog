/site.webmanifest
  Cache-Control: public, no-cache, max-age=0, must-revalidate
/manifest.webmanifest
  Cache-Control: public, no-cache, max-age=0, must-revalidate
/robots.txt
  Cache-Control: public, no-cache, max-age=0, must-revalidate
/favicon.ico
