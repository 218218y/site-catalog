# Cloudflare Pages / static hosting: keep this build out of search results while it is under construction.
# Do not replace this with robots.txt Disallow; Google must be able to crawl the page to see noindex.
/*
  X-Robots-Tag: noindex, nofollow, noimageindex, nosnippet, noarchive
  Strict-Transport-Security: max-age=31536000

# Cloudflare Pages / static hosting headers for fast catalog browsing.
# HTML and code stay revalidated so updates arrive quickly.
/*.html
  Cache-Control: public, max-age=0, must-revalidate
/
  Cache-Control: public, max-age=0, must-revalidate
/*.js
  Cache-Control: public, max-age=0, must-revalidate
/*.css
  Cache-Control: public, max-age=0, must-revalidate

# Catalog page images are referenced with ?v=<assetVersion>, so they can be cached aggressively
# after each conversion/build.
/assets/pages/*
  Cache-Control: public, max-age=31536000, immutable

# PDFs are not required for the live viewer, but cache them well if deployed intentionally.
/assets/pdfs/*
  Cache-Control: public, max-age=31536000, immutable
