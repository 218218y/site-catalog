# Netlify / static hosting headers for fast catalog browsing.
# HTML, runtime config and code stay revalidated so updates arrive quickly.
/*.html
  Cache-Control: public, max-age=0, must-revalidate
/
  Cache-Control: public, max-age=0, must-revalidate
/*.js
  Cache-Control: public, max-age=0, must-revalidate
/*.css
  Cache-Control: public, max-age=0, must-revalidate

# Catalog page images are referenced with ?v=<assetVersion>, so they can be cached aggressively
# when images are still deployed locally to Netlify. In R2 mode these files are not included here.
/assets/pages/*
  Cache-Control: public, max-age=31536000, immutable

# PDFs are not required for the live viewer, but cache them well if deployed intentionally.
/assets/pdfs/*
  Cache-Control: public, max-age=31536000, immutable
