# Content-hashed assets are immutable. Each deployment contains exactly one
# current asset generation, built and validated together with its HTML files.
/static/*
  Cache-Control: public, max-age=31536000, immutable

# Legacy/local Pages image path. The public R2 bundle normally does not copy assets/pages into Pages;
# live catalog images are served from the configured R2/CDN domain with their own cache policy.
/assets/pages/*
  Cache-Control: public, max-age=31536000, immutable

# PDFs are not required for the live viewer, but cache them well if deployed intentionally.
/assets/pdfs/*
  Cache-Control: public, max-age=31536000, immutable
